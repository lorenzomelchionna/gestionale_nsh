# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (Docker Compose): porta 5433 mappata dall'host
DATABASE_URL=postgresql+asyncpg://nsh:nshpass@localhost:5433/new_style_hair
# Railway: usa l'URL interno fornito dal plugin PostgreSQL
# DATABASE_URL=postgresql+asyncpg://<user>:<pass>@<host>:<port>/<db>

POSTGRES_USER=nsh
POSTGRES_PASSWORD=nshpass
POSTGRES_DB=new_style_hair

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev
REDIS_URL=redis://localhost:6379/0
# Railway: usa l'URL interno fornito dal plugin Redis
# REDIS_URL=redis://default:<pass>@<host>:<port>

# ── JWT ───────────────────────────────────────────────────────────────────────
# OBBLIGATORIO in produzione: stringa random >= 32 caratteri
SECRET_KEY=change_me_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@newstylair.it
EMAILS_FROM_NAME=New Style Hair

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
# URL pubblico del frontend (Railway: es. https://nsh-frontend.up.railway.app)
FRONTEND_URL=http://localhost:5173

# ── Frontend (build-time) ─────────────────────────────────────────────────────
# URL pubblico del backend — usato da Vite al build time
# Railway: https://<backend-service>.up.railway.app
VITE_API_URL=

# ── Sentry (opzionale) ────────────────────────────────────────────────────────
# Lascia vuoto per disabilitare il monitoraggio errori
SENTRY_DSN=

# ── Twilio WhatsApp (opzionale) ───────────────────────────────────────────────
# Lascia vuoto per stub mode (messaggi loggati in console, niente invii reali)
# Sandbox Twilio: TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
